  "__changelog": [
    {
      "version": "3.0.0",
      "date": "2026-06-07",
      "changes": [
        "Separated currencies: 🪙 Coins (battles/gambling/shop) and 🩷 Cute Coins (chatting)",
        "Steal system: ,steal @user with currency picker, random 1-1000, 50% success, half penalty on fail",
        "Reset economy: ,reseteconomy / /reseteconomy — wipes all coins + cute coins (bot-creator only)",
        "Multi-leaderboard: ,lb now shows 8 categories with button navigation (coins, cute coins, level, wins, streak, ratio, inventory value, rarest weapon)",
        "Slash versions added: /huntadmin (with subcommand dropdown), /promoview",
        "All prefix commands now have matching slash command equivalents",
        "Inventory command (,inv) shows category buttons then items sorted least→most rare"
      ]
    },
    {
      "version": "2.2.0",
      "date": "June 7, 2026",
      "changes": [
        "20 new enemies: Tier 16 (Transcendence, Nova Beast, Eternal One, Paradox), Tier 17 (Infinity Worm, Absolute Being, Cosmic Overlord, The Endless), Tier 15+ (Eternal Phoenix, Dimension Walker), and extras for Tiers 3, 5, 7, 9, 11, 13",
        "3 new ultra bosses: World Eater, Aetherius, The Great Old One (level 80+)",
        "16 new weapons across all rarities: Stone Hatchet, Training Sword, Rune Knife, Barbarian Axe, Rune Blade, Arcane Staff, Rune Greatsword, Arcane Blade, Rune Hammer, Nightfall, Rift Blade, Eternity, Primal Fury, Starlight, Oblivion Edge, Singularity",
        "16 new armor pieces across all rarities: Straw Cape, Patchwork Vest, Iron Bracers, Rune Cape, Rune Plate, Arcane Robe, Rune Guard, Arcane Shield, Rune Armor, Eternal Guard, Rift Plate, Eternity Cloak, Primal Aegis, Starlight Plate, Oblivion Guard, Singularity Shell",
        "8 new potions: Herb Poultice, Healing Salve, Greater Potion, Ancient Potion, Divine Potion (+50 temp HP), Eternal Elixir (+10 perm HP), Cosmic Renewal (restore + buffs +3), Absolute Essence (+25 perm HP +1 Atk/Def)",
        "6 new buff potions: Sharpshooter Potion (+10 Atk/4 battles), Barrier Potion (+10 Def/4 battles), Frenzy Potion (+40 Atk/3 battles), Bulwark Potion (+20 Def/4 battles), Titan Potion (+40 Atk & +20 Def/4 battles), Godmode Potion (+200 Atk & +100 Def/1 battle)",
        "5 new XP gems: Fractured (1.2x), Flawed (1.35x), Polished (2.5x), Radiant (4x), Brilliant (7.5x)",
        "3 new chests: Reinforced Chest (Rare+), Celestial Chest (Legendary+), Void Chest (Mythical+)",
        "Special potion effects implemented: temp HP, permanent max HP, stat boosts, and buff extensions",
        "New chest types with tier+ loot pools (Reinforced/Celestial/Void Chests)",
        "All new items added to drop tables and usable via ,use and /use commands"
      ]
    },
    {
      "version": "2.1.0",
      "date": "June 7, 2026",
      "changes": [
        "Purchase DMs now show granted roles, balance, and unlocked permissions after buying a tier",
        "Tier 3 also grants role 1512591214640234619 (custom role creation access)",
        "Custom reaction role system (independent of Carl-bot) with /rr-setup (add/remove/list/interactive/scan)",
        "Reaction role DM notifications when role is added or removed",
        "Promoview command to preview advertise reach (excludes bbydollz members)",
        "Advertise now excludes users already in the bbydollz server",
        "Max gamble bet increased from 2,500 to 25,000 coins",
        "Bot owner panel (,huntadmin) for editing any player's HP, atk, def, weapon, armor, gem, and items",
        "Chain battle command: ,ha @user chain <N> to fight N battles at once with a summary",
        "15 new monsters added (Tier 13-15): Astral Beast, Void Lord, Storm Giant, Celestial Drake, World Serpent, Fate Spinner, Reaper, Nightmare, Apocalypse, Creator, Omega, The One, and more",
        "8 boss monsters with 5% spawn chance and massive rewards",
        "New weapons: Crystal Sword, Bone Club, Silver Rapier, Venom Stinger, Inferno Blade, Storm Bringer, Void Scythe, Heaven's Fall",
        "New armor: Wooden Shield, Bone Armor, Silver Mail, Inferno Guard, Storm Shield, Void Mantle, Heaven's Bulwark",
        "New potions: Minor Heal, Mega Potion, Ultra Potion, Elixir of Rebirth, Philosopher's Stone",
        "New buffs: Fortitude Potion, Rage Potion, Guardian Elixir, Overdrive Potion",
        "8 chests (Common → Secret) — use them to get random weapon/armor of matching rarity",
        "8 XP gems (Tiny 1.5x → Celestial 10000x) — equip for passive XP multiplier",
        "XP gem multiplier shown in profile, battle results, and autohunt",
        "Fixed reaction roles not working after bot restart (added Partials for Message/Channel/Reaction)",
        "New buff potion support added to ,use and /use commands"
      ]
    },
    {
      "version": "2.0.0",
      "date": "June 7, 2026",
      "changes": [
        "Unified all help commands into one — /dollhelp (prefix: ,Dollhelp) with button-navigated pages by category",
        "Item rarity system: 8 tiers (Common → Secret) with weighted drops",
        "36 enemies (was 6) across 12 difficulty tiers",
        "40+ new items across all rarity tiers — weapons, armor, and potions",
        "New buff potions: Elixir of Power (+20 Atk), Berserker Brew (+35 Atk, -10 Def), Divine Blessing (all buffs)",
        "atkBoost/defBoost buff fields added to BattlePlayer with migration",
        "All battle files updated to apply atkBoost/defBoost in combat",
        "Epic+ drops show a special ★ INCREDIBLE! announcement",
        "Autohunt changed from 30s interval to immediate battle chaining",
        "Default HP changed from 60 to 250 with player migration",
        "/items (split into Weapons/Armor/Potions & Buffs pages) with button navigation",
        "Tier 3 role requirement added to autohunt with one-click buy prompt",
        "All help files (prefix + slash) updated with complete command listings",
        "Shop tiers are now one-time purchase only (role ownership check)"
      ]
    },
    {
      "version": "1.1.0",
      "date": "June 7, 2026",
      "changes": [
